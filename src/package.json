{
  "name": "vibearound",
  "private": true,
  "workspaces": ["desktop-ui", "web", "desktop", "shared/client-ts", "shared/ui"],
  "scripts": {
    "prebuild": "bun run desktop-ui:build && bun run web:build",
    "build": "bun run desktop:build",
    "dev": "bun run desktop:dev",
    "desktop-ui:dev": "bun run --cwd desktop-ui dev",
    "desktop-ui:build": "bun run --cwd desktop-ui build",
    "web:dev": "bun run --cwd web dev",
    "web:build": "bun run --cwd web build",
    "server:dev": "cargo run -p server",
    "server:build": "cargo build -p server",
    "desktop:dev": "bun run --filter @vibearound/tauri dev",
    "desktop:build": "bun run --filter @vibearound/tauri build",
    "plugins:install": "node scripts/plugin-runner.mjs install",
    "plugins:build": "node scripts/plugin-runner.mjs build",
    "plugin:feishu:build": "node scripts/plugin-runner.mjs build feishu",
    "plugin:telegram:build": "node scripts/plugin-runner.mjs build telegram",
    "plugin:weixin-openclaw-bridge:build": "node scripts/plugin-runner.mjs build weixin-openclaw-bridge"
  },
  "devDependencies": {}
}
