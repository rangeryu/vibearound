{
  "workspaces": [],
  "enabled_agents": ["claude", "gemini", "opencode", "codex"],
  "integrations": {
    "mcp_auto_install": true,
    "skill_auto_install": true
  },
  "search_tool": {
    "enabled": false,
    "stdio_path": "",
    "sources": {
      "exa": {
        "enabled": false,
        "api_key": "YOUR_EXA_API_KEY",
        "api_key_env": "EXA_API_KEY",
        "base_url": "https://api.exa.ai"
      },
      "tavily": {
        "enabled": false,
        "api_key": "YOUR_TAVILY_API_KEY",
        "api_key_env": "TAVILY_API_KEY",
        "base_url": "https://api.tavily.com"
      },
      "grok": {
        "enabled": false,
        "api_key": "YOUR_XAI_API_KEY",
        "api_key_env": "XAI_API_KEY",
        "base_url": "https://api.x.ai/v1"
      }
    }
  },
  "tunnel": {
    "provider": "ngrok",
    "ngrok": {
      "auth_token": "YOUR_NGROK_AUTH_TOKEN",
      "domain": "your-reserved.ngrok.io"
    },
    "cloudflare": {
      "tunnel_token": "YOUR_CLOUDFLARE_TUNNEL_TOKEN",
      "hostname": "vibe.yourdomain.com"
    }
  },
  "channels": {
    "telegram": {
      "bot_token": "YOUR_TELEGRAM_BOT_TOKEN",
      "verbose": {
        "show_thinking": false,
        "show_tool_use": false
      }
    },
    "feishu": {
      "app_id": "YOUR_FEISHU_APP_ID",
      "app_secret": "YOUR_FEISHU_APP_SECRET",
      "verbose": {
        "show_thinking": false,
        "show_tool_use": false
      }
    }
  }
}
