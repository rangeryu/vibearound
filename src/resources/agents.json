[
  {
    "id": "claude",
    "display_name": "Claude Code",
    "description": "Anthropic Claude Code",
    "aliases": ["claude", "claude-code"],
    "acp": {
      "program": "node",
      "npm_package": "@agentclientprotocol/claude-agent-acp",
      "bin_name": "claude-agent-acp"
    },
    "pty": {
      "command": "claude code --permission-mode acceptEdits"
    },
    "resume_template": "cd {cwd} && claude --resume {session_id}",
    "global_config": {
      "settings_path": ".claude/settings.json",
      "mcp_key": "mcpServers",
      "mcp_entry": { "url": "{mcp_url}", "_metadata": "vibearound {version}" },
      "skill_dir": ".claude/skills/vibearound"
    }
  },
  {
    "id": "gemini",
    "display_name": "Gemini CLI",
    "description": "Google Gemini CLI",
    "aliases": ["gemini", "gemini-cli"],
    "acp": {
      "program": "gemini",
      "args": ["--experimental-acp"]
    },
    "pty": {
      "command": "gemini"
    },
    "resume_template": "cd {cwd} && gemini",
    "global_config": {
      "settings_path": ".gemini/settings.json",
      "mcp_key": "mcpServers",
      "mcp_entry": { "httpUrl": "{mcp_url}", "_metadata": "vibearound {version}" }
    }
  },
  {
    "id": "opencode",
    "display_name": "Opencode",
    "description": "OpenCode AI Agent",
    "aliases": ["opencode", "open-code"],
    "acp": {
      "program": "opencode",
      "args": ["acp"]
    },
    "pty": {
      "command": "opencode"
    }
  },
  {
    "id": "codex",
    "display_name": "Codex CLI",
    "description": "OpenAI Codex CLI",
    "aliases": ["codex", "openai-codex"],
    "acp": {
      "program": "node",
      "npm_package": "@zed-industries/codex-acp",
      "bin_name": "codex-acp"
    },
    "pty": {
      "command": "codex"
    }
  }
]
