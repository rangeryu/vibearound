{
  "id": "moonshot",
  "label": "Moonshot / Kimi",
  "icon": "🌙",
  "homepage": "https://platform.moonshot.cn",
  "endpoints": [
    {
      "api_type": "anthropic",
      "default_base_url": "https://api.moonshot.cn/anthropic",
      "models": [
        {
          "id": "kimi-k2-0905-preview",
          "label": "Kimi K2 (0905 preview)"
        },
        {
          "id": "kimi-k2-turbo-preview",
          "label": "Kimi K2 turbo (preview)"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "Moonshot API key",
              "secret": true,
              "required": true,
              "placeholder": "sk-..."
            }
          ],
          "render": {
            "env": {
              "ANTHROPIC_API_KEY": "{{api_key}}",
              "ANTHROPIC_BASE_URL": "{{base_url}}",
              "ANTHROPIC_MODEL": "{{model}}"
            },
            "settings_files": []
          }
        }
      ]
    },
    {
      "api_type": "openai-chat",
      "default_base_url": "https://api.moonshot.cn/v1",
      "models": [
        {
          "id": "kimi-k2-0905-preview",
          "label": "Kimi K2 (0905 preview)"
        },
        {
          "id": "moonshot-v1-32k",
          "label": "Moonshot v1 32K"
        },
        {
          "id": "moonshot-v1-128k",
          "label": "Moonshot v1 128K"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "Moonshot API key",
              "secret": true,
              "required": true,
              "placeholder": "sk-..."
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"moonshot\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.moonshot]\nname = \"Moonshot\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    }
  ]
}
