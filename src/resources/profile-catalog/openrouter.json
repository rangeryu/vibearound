{
  "id": "openrouter",
  "label": "OpenRouter",
  "icon": "🛣️",
  "homepage": "https://openrouter.ai",
  "endpoints": [
    {
      "api_type": "openai-chat",
      "default_base_url": "https://openrouter.ai/api/v1",
      "models": [
        {
          "id": "anthropic/claude-sonnet-4.5",
          "label": "Claude Sonnet 4.5 (via OpenRouter)",
          "capabilities": {
            "image_input": true,
            "file_input": true
          }
        },
        {
          "id": "openai/gpt-4o",
          "label": "GPT-4o (via OpenRouter)",
          "capabilities": {
            "image_input": true,
            "file_input": true
          }
        },
        {
          "id": "deepseek/deepseek-chat",
          "label": "DeepSeek Chat (via OpenRouter)"
        },
        {
          "id": "google/gemini-2.5-pro",
          "label": "Gemini 2.5 Pro (via OpenRouter)",
          "capabilities": {
            "image_input": true,
            "file_input": true
          }
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "OpenRouter API key",
              "secret": true,
              "required": true,
              "placeholder": "sk-or-..."
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"openrouter\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.openrouter]\nname = \"OpenRouter\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    }
  ]
}
