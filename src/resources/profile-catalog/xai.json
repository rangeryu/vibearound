{
  "id": "xai",
  "label": "xAI / Grok",
  "icon": "xAI",
  "homepage": "https://docs.x.ai",
  "endpoints": [
    {
      "api_type": "openai-responses",
      "default_base_url": "https://api.x.ai/v1",
      "append_v1_path": false,
      "models": [
        {
          "id": "grok-4.3",
          "label": "Grok 4.3",
          "aliases": [
            "grok-4.3-latest",
            "grok-latest",
            "grok-4",
            "grok-4-latest",
            "grok-4-0709",
            "grok-3",
            "grok-3-latest",
            "grok-3-mini",
            "grok-3-mini-latest",
            "grok-3-mini-fast"
          ],
          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "grok-build-0.1",
          "label": "Grok Build 0.1",
          "aliases": ["grok-code-fast-1", "grok-code-fast", "grok-code-fast-1-0825"],
          "context_window": 256000,
          "capabilities": {
            "image_input": true
          }
        }
      ],
      "capabilities": {
        "reasoning_effort": true,
        "content": {
          "image_input": true
        }
      },
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use xAI API key",
          "fields": [
            {
              "name": "api_key",
              "label": "xAI API key",
              "secret": true,
              "required": true,
              "placeholder": "xai-..."
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"xai\"\nmodel_reasoning_effort = \"{{reasoning_effort}}\"\ndisable_response_storage = true\n\n[model_providers.xai]\nname = \"xAI / Grok\"\nbase_url = \"{{base_url}}\"\nwire_api = \"responses\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    },
    {
      "api_type": "openai-chat",
      "default_base_url": "https://api.x.ai/v1",
      "append_v1_path": false,
      "models": [
        {
          "id": "grok-4.3",
          "label": "Grok 4.3",
          "aliases": [
            "grok-4.3-latest",
            "grok-latest",
            "grok-4",
            "grok-4-latest",
            "grok-4-0709",
            "grok-3",
            "grok-3-latest",
            "grok-3-mini",
            "grok-3-mini-latest",
            "grok-3-mini-fast"
          ],
          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "grok-build-0.1",
          "label": "Grok Build 0.1",
          "aliases": ["grok-code-fast-1", "grok-code-fast", "grok-code-fast-1-0825"],
          "context_window": 256000,
          "capabilities": {
            "image_input": true
          }
        }
      ],
      "capabilities": {
        "reasoning_effort": true,
        "content": {
          "image_input": true
        }
      },
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use xAI API key",
          "fields": [
            {
              "name": "api_key",
              "label": "xAI API key",
              "secret": true,
              "required": true,
              "placeholder": "xai-..."
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"xai\"\nmodel_reasoning_effort = \"{{reasoning_effort}}\"\ndisable_response_storage = true\n\n[model_providers.xai]\nname = \"xAI / Grok\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    }
  ]
}
