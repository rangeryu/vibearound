    {
      "id": "coding-plan",
      "label": "Coding Plan International",
      "api_type": "openai-chat",
      "default_base_url": "https://coding-intl.dashscope.aliyuncs.com/v1",
      "headers": {
        "User-Agent": "codex-cli/0.80.0 (external, cli)",
        "X-DashScope-AuthType": "openai",
        "X-DashScope-CacheControl": "enable",
        "X-DashScope-UserAgent": "codex-cli/0.80.0 (external, cli)"
      },
      "models": [
        {
          "id": "qwen3.7-plus",
          "label": "qwen3.7-plus",
          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "qwen3.6-plus",
