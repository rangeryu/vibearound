{
  "id": "dashscope",
  "label": "Alibaba DashScope",
  "icon": "D",
  "homepage": "https://help.aliyun.com/zh/model-studio/more-tools",
  "endpoints": [
    {
      "id": "coding-plan",
      "label": "Coding Plan International",
      "api_type": "anthropic",
      "default_base_url": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic",
      "headers": {
        "User-Agent": "claude-code/0.1.0"
      },
      "auth_header": true,
      "models": [
        {
          "id": "qwen3.7-plus",
          "label": "qwen3.7-plus",
          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "qwen3.6-plus",
          "label": "qwen3.6-plus",
          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "kimi-k2.5",
          "label": "kimi-k2.5",
          "context_window": 256000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "glm-5",
          "label": "glm-5"
        },
        {
          "id": "MiniMax-M2.5",
          "label": "MiniMax-M2.5"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "DashScope API key",
              "secret": true,
              "required": true
            }
          ],
          "render": {
            "env": {
              "ANTHROPIC_AUTH_TOKEN": "{{api_key}}",
              "ANTHROPIC_BASE_URL": "{{base_url}}",
              "ANTHROPIC_MODEL": "{{model}}"
            },
            "settings_files": []
          }
        }
      ]
    },
