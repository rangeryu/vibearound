          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "kimi-k2.5",
          "label": "kimi-k2.5",
          "context_window": 256000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "glm-5",
          "label": "glm-5"
        },
        {
          "id": "MiniMax-M2.5",
          "label": "MiniMax-M2.5"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "DashScope API key",
              "secret": true,
              "required": true
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"dashscope\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.dashscope]\nname = \"Alibaba DashScope\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    },
