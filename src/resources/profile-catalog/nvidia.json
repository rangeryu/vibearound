{
  "id": "nvidia",
  "label": "NVIDIA NIM",
  "icon": "N",
  "homepage": "https://build.nvidia.com",
  "endpoints": [
    {
      "api_type": "openai-chat",
      "default_base_url": "https://integrate.api.nvidia.com/v1",
      "append_v1_path": false,
      "models": [
        {
          "id": "nvidia/nemotron-3-super-120b-a12b",
          "label": "Nemotron 3 Super 120B A12B"
        },
        {
          "id": "nvidia/nemotron-3-nano-30b-a3b",
          "label": "Nemotron 3 Nano 30B A3B"
        },
        {
          "id": "nvidia/nvidia-nemotron-nano-9b-v2",
          "label": "NVIDIA Nemotron Nano 9B V2"
        },
        {
          "id": "qwen/qwen3-coder-480b-a35b-instruct",
          "label": "Qwen3 Coder 480B A35B Instruct (via NVIDIA NIM)"
        },
        {
          "id": "openai/gpt-oss-120b",
          "label": "GPT-OSS 120B (via NVIDIA NIM)"
        },
        {
          "id": "moonshotai/kimi-k2.6",
          "label": "Kimi K2.6 (via NVIDIA NIM)"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use NVIDIA API key",
          "fields": [
            {
              "name": "api_key",
              "label": "NVIDIA API key",
              "secret": true,
              "required": true,
              "placeholder": "nvapi-..."
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"nvidia\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.nvidia]\nname = \"NVIDIA NIM\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    }
  ]
}
