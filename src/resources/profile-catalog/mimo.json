{
  "id": "mimo",
  "label": "Xiaomi MiMo",
  "icon": "Mi",
  "homepage": "https://platform.xiaomimimo.com",
  "endpoints": [
    {
      "id": "pay-as-you-go",
      "label": "Pay-as-you-go",
      "api_type": "openai-chat",
      "default_base_url": "https://api.xiaomimimo.com/v1",
      "append_v1_path": false,
      "capabilities": {
        "content": {
          "web_search": true
        }
      },
      "models": [
        {
          "id": "mimo-v2.5-pro",
          "label": "MiMo V2.5 Pro",
          "context_window": 1000000
        },
        {
          "id": "mimo-v2.5",
          "label": "MiMo V2.5",
          "context_window": 1000000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "mimo-v2-pro",
          "label": "MiMo V2 Pro",
          "context_window": 1000000
        },
        {
          "id": "mimo-v2-omni",
          "label": "MiMo V2 Omni",
          "context_window": 256000,
          "capabilities": {
            "image_input": true
          }
        },
        {
          "id": "mimo-v2-flash",
          "label": "MiMo V2 Flash",
          "context_window": 256000
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use MiMo API key",
          "fields": [
            {
              "name": "api_key",
              "label": "MiMo API key",
              "secret": true,
              "required": true,
              "placeholder": "sk-..."
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"mimo\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.mimo]\nname = \"Xiaomi MiMo\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "token-plan-cn",
      "label": "Token Plan CN",
      "api_type": "openai-chat",
