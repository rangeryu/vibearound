{
  "id": "zai",
  "label": "Z.AI / GLM",
  "icon": "🧊",
  "homepage": "https://docs.z.ai",
  "endpoints": [
    {
      "id": "global",
      "label": "Global API",
      "api_type": "openai-chat",
      "default_base_url": "https://api.z.ai/api/paas/v4",
      "models": [
        {
          "id": "glm-5.2",
          "label": "GLM-5.2",
          "aliases": [
            "glm-5.2[1m]"
          ],
          "context_window": 1000000
        },
        {
          "id": "glm-5-turbo",
          "label": "GLM-5 Turbo",
          "context_window": 200000
        },
        {
          "id": "glm-5v-turbo",
          "label": "GLM-5V Turbo",
          "context_window": 200000,
          "capabilities": {
            "image_input": true,
            "file_input": true
          }
        },
        {
          "id": "glm-5.1",
          "label": "GLM-5.1",
          "context_window": 200000
        },
        {
          "id": "glm-4.7",
          "label": "GLM-4.7",
          "context_window": 200000
        },
        {
          "id": "glm-4.5-air",
          "label": "GLM-4.5 Air"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "Z.AI API key",
              "secret": true,
              "required": true
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"zai\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.zai]\nname = \"Z.AI\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    },
