{
  "id": "zai",
  "label": "Z.AI / GLM",
  "icon": "🧊",
  "homepage": "https://docs.z.ai",
  "endpoints": [
    {
      "api_type": "anthropic",
      "default_base_url": "https://api.z.ai/api/anthropic",
      "models": [
        {
          "id": "glm-5.1",
          "label": "GLM-5.1",
          "context_window": 200000
        },
        {
          "id": "glm-5",
          "label": "GLM-5",
          "context_window": 200000
        },
        {
          "id": "glm-4.7",
          "label": "GLM-4.7",
          "context_window": 200000
        },
        {
          "id": "glm-4.6",
          "label": "GLM-4.6",
          "context_window": 200000
        },
        {
          "id": "glm-4.5",
          "label": "GLM-4.5",
          "context_window": 128000
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "Z.AI API key",
              "secret": true,
              "required": true
            }
          ],
          "render": {
            "env": {
              "ANTHROPIC_API_KEY": "{{api_key}}",
              "ANTHROPIC_BASE_URL": "{{base_url}}",
              "ANTHROPIC_MODEL": "{{model}}"
            },
            "settings_files": []
          }
        }
      ]
    },
    {
      "id": "global",
      "label": "Global",
      "api_type": "openai-chat",
      "default_base_url": "https://api.z.ai/api/paas/v4",
      "models": [
        {
          "id": "glm-5.1",
          "label": "GLM-5.1",
          "context_window": 200000
        },
        {
          "id": "glm-5",
          "label": "GLM-5",
          "context_window": 200000
        },
        {
          "id": "glm-5-turbo",
          "label": "GLM-5 Turbo",
          "context_window": 200000
        },
        {
          "id": "glm-5v-turbo",
          "label": "GLM-5V Turbo",
          "capabilities": {
            "image_input": true,
            "file_input": true
          },
          "context_window": 200000
        },
        {
          "id": "glm-4.7",
          "label": "GLM-4.7",
          "context_window": 200000
        },
        {
          "id": "glm-4.7-flash",
          "label": "GLM-4.7 Flash"
        },
        {
          "id": "glm-4.7-flashx",
          "label": "GLM-4.7 FlashX"
        },
        {
          "id": "glm-4.6",
          "label": "GLM-4.6",
          "context_window": 200000
        },
        {
          "id": "glm-4.6v",
          "label": "GLM-4.6V",
          "capabilities": {
            "image_input": true,
            "file_input": true
          }
        },
        {
          "id": "glm-4.5",
          "label": "GLM-4.5",
          "context_window": 128000
        },
        {
          "id": "glm-4.5-air",
          "label": "GLM-4.5 Air"
        },
        {
          "id": "glm-4.5-flash",
          "label": "GLM-4.5 Flash"
        },
        {
          "id": "glm-4.5v",
          "label": "GLM-4.5V",
          "capabilities": {
            "image_input": true,
            "file_input": true
          }
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "Z.AI API key",
              "secret": true,
              "required": true
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"zai\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.zai]\nname = \"Z.AI\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    },
